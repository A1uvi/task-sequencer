# Database
DATABASE_URL=postgresql+asyncpg://aiworkflow:aiworkflow@localhost:5432/aiworkflow
TEST_DATABASE_URL=postgresql+asyncpg://aiworkflow:aiworkflow@localhost:5432/aiworkflow_test

# Security
# Generate SECRET_KEY with: openssl rand -hex 32
SECRET_KEY=replace_with_64_char_hex
# Generate ENCRYPTION_KEY with: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=replace_with_32_byte_base64

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Redis
REDIS_URL=redis://localhost:6379/0

# Email — choose "sendgrid" or "smtp"
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
FROM_EMAIL=noreply@yourdomain.com
# SMTP fallback (if EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Frontend
VITE_API_BASE_URL=http://localhost:8000
